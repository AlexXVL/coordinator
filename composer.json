{
    "name": "alexxvl/coordinator",
    "description": "Schedule and manage resource booking (appointments) in your Laravel app",
    "keywords": [
        "appointment",
        "booking",
        "eloquent",
        "event",
        "laravel",
        "schedule"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.0",
        "illuminate/support": "^8.0|^9.0|^10.0|^11.0",
        "spatie/laravel-package-tools":"^1.0",
        "spatie/period": "^2.0"
    },
    "require-dev": {
        "orchestra/testbench": "^6.0|^7.0|^8.0|^9.0",
        "phpunit/phpunit": "^9.4|^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "AlexXVL\\Coordinator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "coverage": "XDEBUG_MODE=coverage ./vendor/bin/phpunit --coverage-html coverage -d pcov.enabled",
        "test": "./vendor/bin/phpunit --color=always -vvv"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "AlexXVL\\Coordinator\\CoordinatorServiceProvider"
            ]
        }
    }
}
